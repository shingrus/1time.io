---
import {minifyCss} from '../lib/minifyCss.js';

import globalsCss from '../styles/globals.css?raw';
import homeCss from '../styles/home.css?raw';
import fileSharingCss from '../styles/file-sharing.css?raw';
import linkCss from '../styles/link.css?raw';
import qrPanelCss from '../styles/qr-panel.css?raw';
import viewCss from '../styles/view.css?raw';
import statsCss from '../styles/stats.css?raw';

const cssByName = {
    globals: globalsCss,
    home: homeCss,
    'file-sharing': fileSharingCss,
    link: linkCss,
    'qr-panel': qrPanelCss,
    view: viewCss,
    stats: statsCss,
} as const;

const minified = new Map<string, string>();

function getMinified(name: keyof typeof cssByName): string {
    if (!minified.has(name)) {
        minified.set(name, minifyCss(cssByName[name]));
    }
    return minified.get(name)!;
}

interface Props {
    name: keyof typeof cssByName;
}

const {name} = Astro.props;
const css = getMinified(name);
---
<style set:html={css} data-inline-css={name}></style>
