{
    "manifest_version": 3,
    "name": "1time — One-Time Secret Links",
    "version": "1.0.2",
    "description": "Encrypt selected text in your browser and copy a one-time link. Supports 1time.io and self-hosted servers.",
    "minimum_chrome_version": "116",
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_title": "1time — One-Time Secret Links",
        "default_popup": "popup.html"
    },
    "options_ui": {
        "page": "popup.html",
        "open_in_tab": true
    },
    "permissions": [
        "storage",
        "scripting",
        "activeTab",
        "clipboardWrite",
        "contextMenus",
        "offscreen"
    ],
    "host_permissions": [
        "https://1time.io/*"
    ],
    "optional_host_permissions": [
        "https://*/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
    ],
    "commands": {
        "share-selection": {
            "suggested_key": {
                "default": "Alt+Shift+S"
            },
            "description": "Share passwords & secrets as encrypted one-time links. Select text, right-click, done — zero-knowledge, self-hosted ready."
        }
    }
}
