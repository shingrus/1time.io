FROM golang:1.22-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY backend ./backend
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags "-w -s" -o /out/1time-api ./backend

FROM alpine:3.21

RUN apk add --no-cache ca-certificates && mkdir -p /var/lib/1time/files

COPY --from=builder /out/1time-api /usr/local/bin/1time-api

ENV LISTEN_ADDR=0.0.0.0:8080
ENV FILE_STORAGE_DIR=/var/lib/1time/files

EXPOSE 8080

CMD ["1time-api"]
