---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InlineCss from '../../components/InlineCss.astro';
import {siteHost} from '../../lib/siteConfig.js';

const title = `View Secret Message — ${siteHost}`;
const description = 'Open an encrypted one-time secret link shared through 1time.io. The secret is decrypted in your browser and destroyed after reading.';
---
<BaseLayout
    title={title}
    description={description}
    canonical="/v/"
    ogImage="/1time-og-v.png"
    ogImageAlt={`${siteHost} encrypted one-time secret link`}
    robots="noindex, nofollow"
>
    <InlineCss slot="head" name="view" />
    <InlineCss slot="head" name="qr-panel" />

    <div>
        <form id="view-secret-form">
            <div class="alert alert-warning" data-wrong-key hidden>
                Wrong passphrase. Please try again.
            </div>

            <div class="form-field" data-state="passphrase" hidden>
                <label class="form-label" for="secretKey">Passphrase required</label>
                <input
                    autofocus
                    class="form-input"
                    id="secretKey"
                    placeholder="Enter the passphrase from the sender"
                    type="text"
                />
            </div>

            <div data-state="pre-read">
                <div class="confirm-gate">
                    <div class="confirm-gate-icon" aria-hidden="true">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            <circle cx="12" cy="16" r="1"/>
                        </svg>
                    </div>
                    <h2 class="confirm-gate-title">Someone sent you a secret</h2>
                    <p class="confirm-gate-desc">
                        This is a <strong>one-time link</strong>. The message will be revealed once and <strong>immediately deleted</strong> from our servers.
                    </p>
                    <button class="btn btn-success btn-lg" type="submit" data-reveal>Reveal the secret</button>
                </div>
            </div>

            <div data-qr-action>
                <div class="view-secondary-actions">
                    <button class="btn btn-secondary btn-lg" type="button" data-toggle-qr>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M3 3h6v6H3z"/>
                            <path d="M15 3h6v6h-6z"/>
                            <path d="M3 15h6v6H3z"/>
                            <path d="M15 15h3"/>
                            <path d="M18 12v3"/>
                            <path d="M21 15v6"/>
                            <path d="M15 21h3"/>
                            <path d="M21 21h.01"/>
                        </svg>
                        <span data-qr-label>Show QR code</span>
                    </button>
                </div>
                <section class="qr-panel" data-qr-panel hidden aria-live="polite">
                    <p class="qr-panel-title">Scan from another device</p>
                    <p class="qr-panel-note">This QR encodes the same one-time link for this secret.</p>
                    <div class="qr-panel-code">
                        <div aria-label="Secret link QR code" data-qr-slot></div>
                    </div>
                </section>
            </div>

            <div data-state="decrypted" hidden>
                <div class="message-panel">
                    <div class="message-panel-header">
                        <span class="status-dot"></span>
                        Decrypted message
                    </div>
                    <div class="message-panel-body">
                        <pre data-decrypted-body></pre>
                    </div>
                    <div class="message-panel-footer">
                        <button class="btn btn-success btn-sm" type="button" data-copy>
                            <svg data-copy-icon-copy width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                            </svg>
                            <svg data-copy-icon-done width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span data-copy-label>Copy</span>
                        </button>
                    </div>
                </div>
            </div>

            <div data-state="no-message" hidden>
                <div class="destroyed-notice">
                    <p>This message has already been read or has expired.</p>
                    <a class="btn btn-primary" href="/?reply=1">Create your own secret link</a>
                </div>
            </div>

            <div data-state="post-read-cta" hidden>
                <div class="view-cta">
                    <p class="view-cta-destroyed">Message destroyed.</p>
                    <div class="view-cta-box">
                        <p class="view-cta-heading">Need to send something back?</p>
                        <a class="btn btn-primary" href="/?reply=1">Reply with a secret →</a>
                        <p class="view-cta-desc">Paste your reply into the same thread where you got this one.</p>
                    </div>
                </div>
            </div>
        </form>

        <div class="view-powered-by">
            <a href="https://1time.io" target="_blank" rel="noopener noreferrer">
                Powered by <strong>1time.io</strong>
            </a>
            <span class="view-powered-by-tagline">Free, open-source, zero-knowledge encryption. Your secrets are encrypted in the browser — the server never sees them.</span>
        </div>
    </div>

    <script>
        import '../../islands/view-secret.ts';
    </script>
</BaseLayout>
