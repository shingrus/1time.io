---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InlineCss from '../../components/InlineCss.astro';
import {siteHost} from '../../lib/siteConfig.js';

const title = `Download Encrypted File — ${siteHost}`;
const description = 'Open an encrypted one-time file link shared through 1time.io. The file is decrypted in your browser and destroyed after download.';
---
<BaseLayout
    title={title}
    description={description}
    canonical="/f/"
    ogImage="/1time-og-main.png"
    ogImageAlt={`${siteHost} encrypted one-time file link`}
    robots="noindex, nofollow"
>
    <InlineCss slot="head" name="view" />

    <div>
        <form id="view-file-form" autocomplete="off">
            <div class="alert alert-warning" data-wrong-key hidden>
                Wrong passphrase. Please try again.
            </div>

            <div class="form-field" data-state="passphrase" hidden>
                <label class="form-label" for="secretKey">Passphrase required</label>
                <input
                    autofocus
                    class="form-input"
                    id="secretKey"
                    autocomplete="new-password"
                    autocapitalize="none"
                    placeholder="Enter the passphrase from the sender"
                    spellcheck="false"
                    type="password"
                />
            </div>

            <div data-state="pre-read">
                <div class="confirm-gate">
                    <div class="confirm-gate-icon" aria-hidden="true">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            <circle cx="12" cy="16" r="1"/>
                        </svg>
                    </div>
                    <h2 class="confirm-gate-title">Someone sent you a file</h2>
                    <p class="confirm-gate-desc">
                        This is a <strong>one-time link</strong>. The file can be downloaded once and <strong>immediately deleted</strong> from our servers.
                    </p>
                    <button class="btn btn-success btn-lg" type="submit" data-download>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="7 10 12 15 17 10"/>
                            <line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        <span data-download-label>Download the file</span>
                    </button>
                </div>
            </div>

            <div data-state="downloaded" hidden>
                <div class="view-cta">
                    <p class="view-cta-destroyed">File downloaded and permanently destroyed from our servers.</p>
                    <div class="view-cta-box">
                        <p class="view-cta-heading">Need to share a file securely?</p>
                        <p class="view-cta-desc">Create an encrypted, self-destructing link in seconds. Free, no signup required.</p>
                        <a class="btn btn-primary" href="/secure-file-sharing/">Share a file</a>
                    </div>
                </div>
            </div>

            <div data-state="no-message" hidden>
                <div class="destroyed-notice">
                    <p>This file has already been downloaded or has expired.</p>
                    <a class="btn btn-primary" href="/secure-file-sharing/">Share a file</a>
                </div>
            </div>
        </form>

        <div class="view-powered-by">
            <a href="https://1time.io" target="_blank" rel="noopener noreferrer">
                Powered by <strong>1time.io</strong>
            </a>
            <span class="view-powered-by-tagline">Free, open-source, zero-knowledge encryption. Your files are encrypted in the browser — the server never sees them.</span>
        </div>
    </div>

    <script>
        import '../../islands/view-file.ts';
    </script>
</BaseLayout>
