# Required
# DATA_DIR stores both Redis persistence and encrypted uploaded files.
DATA_DIR=./data
APP_HOSTNAME=1time.io

# Optional
APP_PORT=8080
SHOW_BLOG=false

# Backend upstream (host:port) nginx proxies /api/ to.
# Override when your Docker networking needs a different host, e.g. host.docker.internal:8080.
BACKEND_UPSTREAM=backend:8080
